{
  "manifest_version": 3,
  "name": "AI Phishing Guard",
  "version": "1.0",
  "description": "Detect suspicious URLs and redirect to a phishing analysis dashboard.",
  "permissions": ["tabs", "storage", "webNavigation"],
  "host_permissions": ["http://127.0.0.1:5000/*", "http://localhost:5000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Phishing Guard"
  }
}
